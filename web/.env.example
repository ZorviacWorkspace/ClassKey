# Supabase → Project Settings → API. Set these in Vercel too (Production + Preview).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (used by admin "create user" + identifier login lookup). NEVER prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
